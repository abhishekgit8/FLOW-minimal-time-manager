# =============================================
# FLOW SaaS — Environment Configuration
# =============================================
# 1. Go to https://app.supabase.com → your project → Settings → API
# 2. Copy "Project URL" → NEXT_PUBLIC_SUPABASE_URL
# 3. Copy "Publishable" key → NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# Direct Connection String (postgresql://...) is NOT needed.
# That's only for Prisma migrations, pgAdmin, or direct SQL access.
# =============================================

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_KEY_HERE
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Calendar OAuth (optional — only needed for calendar integration)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Token encryption key — generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=
